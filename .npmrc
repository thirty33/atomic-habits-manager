# Disable automatic execution of dependency lifecycle scripts (preinstall /
# install / postinstall / prepare) on `npm install` and `npm ci`.
# Supply-chain hardening: a malicious package cannot run code just by being installed.
# Read by npm on the host AND inside the Sail container (the project is mounted there).
# When a package legitimately needs its install scripts, run them explicitly, e.g.:
#   npm install --ignore-scripts=false        (one-off override)
#   npm rebuild <package>                      (re-run a specific package's scripts)
ignore-scripts=true
